{
  "name": "ua-parser-modern",
  "type": "module",
  "version": "0.0.0",
  "description": "Detect Browser, Engine, OS, CPU, and Device type/model from User-Agent data. Supports browser & node.js environment",
  "author": "Matteo Collina <hello@matteocollina.com>",
  "license": "MIT",
  "homepage": "https://github.com/antfu-collective/ua-parser-modern",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu-collective/ua-parser-modern.git"
  },
  "bugs": "https://github.com/antfu-collective/ua-parser-modern/issues",
  "keywords": [
    "user-agent",
    "parser",
    "browser",
    "engine",
    "os",
    "device",
    "cpu",
    "ua-parser-js",
    "client-hints",
    "user-agent-detection",
    "device-detection",
    "platform-detection",
    "mobile-detection",
    "browser-detection",
    "architecture-detection"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "bench:my-ua-parser": "vitest bench --run bench/compare-my-ua-parser.bench.ts",
    "prepack": "npm run build",
    "release": "bumpp",
    "prepare": "simple-git-hooks",
    "test": "vitest run --typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@types/node": "^24.5.2",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "lint-staged": "^16.3.3",
    "my-ua-parser": "2.0.4",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
